{
  "name": "@creator-os/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --watch dist/main.js",
    "serve": "dotenv -e ../../.env -- cross-env NODE_ENV=development tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@creator-os/config": "workspace:*",
    "@creator-os/database": "workspace:*",
    "@creator-os/types": "workspace:*",
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/platform-express": "^11.1.1",
    "@nestjs/swagger": "^11.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv-cli": "^3.0.0",
    "helmet": "^8.1.0",
    "nest-winston": "^1.10.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsx": "^4.20.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.3"
  }
}
