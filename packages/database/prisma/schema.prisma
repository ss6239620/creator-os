generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  YOUTUBE
  INSTAGRAM
  MOJ
  JOSH
  SHARECHAT
}

enum PlatformConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

enum RevenueSource {
  ADSENSE
  BRAND_DEAL
  AFFILIATE
  COURSE
  SUBSCRIPTION
  TIP
  OTHER
}

enum Currency {
  INR
}

enum PayoutMethod {
  UPI
  BANK_TRANSFER
  OTHER
}

enum NotificationType {
  SYSTEM
  ANALYTICS
  CONTENT
  REVENUE
  BILLING
  SECURITY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum Plan {
  FREE
  PRO
  STUDIO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  creatorSlug  String   @unique
  timezone     String   @default("Asia/Kolkata")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  platformConnections PlatformConnection[]
  analyticsSnapshots  AnalyticsSnapshot[]
  scheduledPosts      ScheduledPost[]
  revenueEntries      RevenueEntry[]
  notifications       Notification[]
  subscription        Subscription?

  @@index([createdAt])
}

model PlatformConnection {
  id            String                    @id @default(cuid())
  userId        String
  platform      Platform
  status        PlatformConnectionStatus  @default(ACTIVE)
  accountId     String
  accountName   String?
  accessToken   String?
  refreshToken  String?
  tokenExpiresAt DateTime?
  scopes        String[]
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, accountId])
  @@index([userId, platform])
  @@index([platform, status])
}

model AnalyticsSnapshot {
  id         String   @id @default(cuid())
  userId     String
  platform   Platform
  accountId  String
  snapshotAt DateTime

  views        BigInt?
  impressions  BigInt?
  reach        BigInt?
  likes        BigInt?
  comments     BigInt?
  shares       BigInt?
  saves        BigInt?
  followers    BigInt?
  subscribers  BigInt?
  watchTimeSec BigInt?

  metrics Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, accountId, snapshotAt])
  @@index([userId, platform, snapshotAt])
}

model ScheduledPost {
  id           String     @id @default(cuid())
  userId       String
  platform     Platform
  accountId    String
  status       PostStatus @default(DRAFT)
  title        String?
  caption      String?
  mediaUrls    String[]
  scheduledAt  DateTime?
  publishedAt  DateTime?
  externalPostId String?
  error        String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, status])
  @@index([platform, accountId, scheduledAt])
}

model RevenueEntry {
  id          String        @id @default(cuid())
  userId      String
  platform    Platform?
  source      RevenueSource
  currency    Currency      @default(INR)
  amountPaisa BigInt
  grossPaisa  BigInt?
  feesPaisa   BigInt?
  taxPaisa    BigInt?
  payoutMethod PayoutMethod?
  payoutRef   String?
  occurredAt  DateTime
  notes       String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([source, occurredAt])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  plan      Plan
  status    SubscriptionStatus @default(TRIALING)
  provider  String?
  providerCustomerId String?
  providerSubscriptionId String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAt           DateTime?
  cancelledAt        DateTime?
  trialEndsAt        DateTime?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, currentPeriodEnd])
}

